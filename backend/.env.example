# Local dev: sqlite:///./ats_resume.db
# Production: postgresql://user:pass@host:5432/ats_resume
DATABASE_URL=sqlite:///./ats_resume.db

SECRET_KEY=change-this-to-a-random-secret-key
CORS_ORIGINS=http://localhost:5173,https://www.profileotimizer.online,https://profileotimizer.online

# Frontend URL (used to build reset-password links in emails)
FRONTEND_URL=http://localhost:5173

# Email / Resend (for password reset emails)
# Get a free API key at https://resend.com
RESEND_API_KEY=re_...
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=ProfileOptimizer

# AI Provider (Groq — get a free API key at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Vector Search (optional — falls back to local keyword matching without these)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=job-matches

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Analytics / GTM
GTM_ID=GTM-PHXK9HX
GA_MEASUREMENT_ID=
GA_API_SECRET=
