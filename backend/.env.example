# Local dev: sqlite:///./ats_resume.db
# Production: postgresql://user:pass@host:5432/ats_resume
DATABASE_URL=sqlite:///./ats_resume.db

SECRET_KEY=change-this-to-a-random-secret-key
CORS_ORIGINS=http://localhost:5173

# Frontend URL (used to build reset-password links in emails)
FRONTEND_URL=http://localhost:5173

# Email / SMTP (for password reset emails)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=ProfileOptimizer

# AI Provider (set at least one for AI features)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Vector Search (optional — falls back to local keyword matching without these)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=job-matches

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
